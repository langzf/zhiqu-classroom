# zhiqu-classroom 后端环境变量（Docker 部署用）
# 复制为 .env 并修改敏感值

# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@zhiqu-postgres:5432/zhiqu

# ── Redis ──
REDIS_URL=redis://zhiqu-redis:6379/0

# ── MinIO ──
MINIO_ENDPOINT=zhiqu-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zhiqu
MINIO_SECURE=false

# ── JWT / Secret ──
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-in-production

# ── LLM ──
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── SMS ──
SMS_PROVIDER=mock

# ── CORS ──
CORS_ORIGINS=["*"]
